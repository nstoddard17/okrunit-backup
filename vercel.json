{
  "crons": [
    {
      "path": "/api/v1/cron/process-escalations",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/v1/cron/weekly-digest",
      "schedule": "0 9 * * 1"
    },
    {
      "path": "/api/v1/cron/purge-deleted-accounts",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/v1/cron/data-retention",
      "schedule": "0 4 * * *"
    }
  ]
}
