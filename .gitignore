# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# integrations — credentials & secrets
integrations/**/.env
integrations/**/.env.*
!integrations/**/.env.example
integrations/zapier/.zapierapprc

# integrations — build artifacts & dependencies
integrations/**/node_modules
integrations/n8n/dist

# secrets & credentials (global catch-all)
*.secret
*.secrets
**/credentials.json
**/service-account*.json
**/*-credentials.json
**/*.p12
**/*.pfx
**/*.keystore

# supabase local
supabase/.temp
**/__pycache__/
integrations/*/dist/
tools/scripts/deploy/screenshots/
tools/scripts/deploy/node_modules/
