{
  "label": "Gatekeeper OAuth2",
  "type": "oauth2",
  "parameters": [
    {
      "name": "baseUrl",
      "type": "url",
      "label": "Gatekeeper URL",
      "required": true,
      "default": "https://gatekeeper.example.com",
      "help": "The base URL of your Gatekeeper instance."
    }
  ],
  "oauth2": {
    "authorizeUrl": "{{parameters.baseUrl}}/oauth/authorize",
    "tokenUrl": "{{parameters.baseUrl}}/api/v1/oauth/token",
    "scope": ["approvals:read", "approvals:write", "comments:write"],
    "scopeSeparator": " ",
    "authStyle": "body"
  },
  "test": {
    "url": "{{parameters.baseUrl}}/api/v1/approvals",
    "method": "GET",
    "headers": {
      "Authorization": "Bearer {{connection.accessToken}}"
    },
    "qs": {
      "page_size": "1"
    },
    "response": {
      "valid": "{{ifempty(body.data, '[]')}}",
      "error": {
        "message": "{{body.error}}"
      }
    }
  }
}
