      "label": "Comment",
      "required": true,
      "help": "The comment text (max 5000 characters)."
    }
  ],
  "url": "/api/v1/approvals/{{parameters.approval_id}}/comments",
  "method": "POST",
  "body": {
    "body": "{{parameters.body}}"
  },
  "response": {
    "output": "{{body}}"
  },
