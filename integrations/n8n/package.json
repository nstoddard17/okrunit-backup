{
  "name": "n8n-nodes-gatekeeper",
  "version": "0.1.0",
  "description": "n8n community node for Gatekeeper human-in-the-loop approval gateway",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "gatekeeper",
    "approval",
    "human-in-the-loop"
  ],
  "license": "MIT",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint . --ext .ts",
    "prepublishOnly": "npm run build"
  },
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/GatekeeperApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Gatekeeper/Gatekeeper.node.js",
      "dist/nodes/Gatekeeper/GatekeeperTrigger.node.js"
    ]
  },
  "devDependencies": {
    "n8n-workflow": "^1.0.0",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
